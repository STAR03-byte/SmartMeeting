# SmartMeeting 生产环境变量模板
# 
# 重要提示：
# 1. 复制此文件为 .env.production 并填入真实值
# 2. .env.production 不应提交到版本控制
# 3. 生产环境建议使用 Docker secrets 或密钥管理系统

# =============================================================================
# 数据库配置（MySQL - 生产必须使用 MySQL，禁止回退 SQLite）
# =============================================================================
DB_HOST=<YOUR_MYSQL_HOST>                          # MySQL 主机地址（如：db 或 mysql.example.com）
DB_PORT=3306                                       # MySQL 端口（默认 3306）
DB_USER=<YOUR_DB_USER>                             # 数据库用户名（如：smartmeeting）
DB_PASSWORD=<YOUR_STRONG_DB_PASSWORD>              # 数据库密码（建议使用 16+ 位随机字符串）
DB_NAME=smartmeeting                               # 数据库名称
DB_BACKEND=mysql                                   # 固定为 mysql，生产不允许回退
DB_AUTO_FALLBACK_SQLITE=false                      # 生产环境禁止回退 SQLite
SQLITE_PATH=/app/data/dev.db                       # SQLite 路径（仅回退时使用）

# =============================================================================
# JWT 安全配置（必须替换为强密钥）
# =============================================================================
# JWT_SECRET_KEY 生成命令（Linux/macOS）：
#   openssl rand -base64 32
# JWT_SECRET_KEY 生成命令（Windows PowerShell）：
#   [Convert]::ToBase64String((1..32 | ForEach-Object { Get-Random -Maximum 256 } | ForEach-Object { [byte]$_ }))
JWT_SECRET_KEY=<YOUR_JWT_SECRET_KEY_32_BYTES_BASE64>  # JWT 签名密钥（32字节 Base64）
JWT_ALGORITHM=HS256                                   # JWT 算法（固定 HS256）
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440                  # Token 过期时间（分钟），默认 24 小时

# =============================================================================
# 认证安全配置
# =============================================================================
AUTH_LOGIN_RATE_LIMIT=5/minute                     # 登录频率限制

# =============================================================================
# LLM 配置（AI 会议总结和任务提取）
# =============================================================================
LLM_PROVIDER=openai                                # LLM 提供商：openai | ollama | mock
LLM_API_KEY=<YOUR_LLM_API_KEY>                     # LLM API 密钥（如 OpenAI 或 Mimo）
LLM_BASE_URL=<YOUR_LLM_BASE_URL>                   # LLM 基础 URL（可选，用于自定义端点）
LLM_MODEL=<YOUR_LLM_MODEL>                         # LLM 模型（如：gpt-4o-mini 或 mimo-v2-flash）
LLM_TEMPERATURE=0.3                                # 温度参数（0-1，越低越确定）
LLM_MAX_TOKENS=2000                                # 最大 Token 数
LLM_TIMEOUT=60                                     # 请求超时（秒）

# LLM 回退配置（主 LLM 失败时使用）
LLM_FALLBACK_PROVIDER=ollama                       # 回退提供商：ollama | mock | none
OLLAMA_BASE_URL=http://host.docker.internal:11434  # Ollama 服务地址
OLLAMA_MODEL=llama3.1                              # Ollama 模型
OLLAMA_TIMEOUT=60                                  # Ollama 超时
OLLAMA_TEMPERATURE=0.3                             # Ollama 温度
OLLAMA_MAX_TOKENS=2000                             # Ollama 最大 Token

# =============================================================================
# Whisper 语音识别配置
# =============================================================================
WHISPER_MODEL=base                                 # Whisper 模型：tiny | base | small | medium | large
WHISPER_DEVICE=cpu                                 # 运行设备：cpu | cuda
WHISPER_LANGUAGE=zh                                # 识别语言：zh（中文）| en（英文）
WHISPER_HOT_WORDS=                                 # 热词列表（逗号分隔，帮助识别专业词汇）
WHISPER_NORMALIZE_TO_SIMPLIFIED=true               # 繁体转简体

# =============================================================================
# 应用配置
# =============================================================================
MEETING_AUDIO_MAX_SIZE_BYTES=104857600             # 会议音频最大文件大小（100MB）