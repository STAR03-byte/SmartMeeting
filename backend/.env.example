APP_NAME=SmartMeeting API
APP_ENV=dev
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root
DB_NAME=smartmeeting
DB_BACKEND=mysql
DB_AUTO_FALLBACK_SQLITE=true
SQLITE_PATH=backend/dev.db

JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

LLM_PROVIDER=openai
LLM_API_KEY=
LLM_BASE_URL=
